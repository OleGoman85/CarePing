generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

// APP OWNER
model Profile {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    name  String
    phone String?

    contacts Contact[]
    plans    Plan[]
}

// STATUS
enum CheckInStatus {
    PENDING
    CONFIRMED
    ESCALATED
    CANCELLED
}

// HELPER
model Contact {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())

    name     String
    phone    String
    priority Int    @default(1)

    profileId String
    profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    logs NotificationLog[]
}

// PLAN
model Plan {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    title      String // "Pills check"
    everyDays  Int // 1-3 (for check-in)
    windowFrom String // "09:00"
    windowTo   String // "11:00"
    isActive   Boolean @default(true)

    profileId String
    profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
    events    CheckInEvent[]
}

// DAY EVENT
model CheckInEvent {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    planId String
    plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

    scheduledFor DateTime
    status       CheckInStatus @default(PENDING)
    attempts     Int           @default(0)

    confirmedAt DateTime?
    escalatedAt DateTime?

    logs NotificationLog[]
}

enum NotifyChannel {
    SMS
    CALL
}

model NotificationLog {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())

    eventId String
    event   CheckInEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

    contactId String?
    contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

    channel NotifyChannel
    toPhone String
    message String
}
